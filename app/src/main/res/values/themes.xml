<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.DemoOttMobile" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ott_primary</item>
        <item name="colorPrimaryVariant">@color/ott_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/ott_surface</item>
        <item name="colorSecondaryVariant">@color/ott_surface</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/ott_background</item>
        <item name="android:windowBackground">@color/ott_background</item>
        <item name="android:textColorPrimary">@color/ott_text_primary</item>
        <item name="android:textColorSecondary">@color/ott_text_secondary</item>
    </style>

    <style name="Theme.DemoOttMobile.FullScreen" parent="Theme.DemoOttMobile">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="OttDialog" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@color/ott_surface</item>
        <item name="android:textColorPrimary">@color/ott_text_primary</item>
        <item name="android:windowMinWidthMajor">80%</item>
        <item name="android:windowMinWidthMinor">80%</item>
    </style>
</resources>